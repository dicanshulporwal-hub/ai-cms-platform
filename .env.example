# App
NODE_ENV=development
PORT=3001
API_BASE_URL=http://localhost:3001
DEFAULT_SUPER_ADMIN_EMAIL=admin@example.com
DEFAULT_SUPER_ADMIN_NAME="Super Admin"
DEFAULT_SUPER_ADMIN_PASSWORD=Admin@12345

# Auth
JWT_SECRET=replace-with-a-long-random-development-secret
JWT_EXPIRES_IN=1d

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=ai_cms
MYSQL_USER=ai_cms_user
MYSQL_PASSWORD=ai_cms_password
MYSQL_ROOT_PASSWORD=password
DATABASE_URL="mysql://root:password@localhost:3306/ai_cms"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# Future AI providers
OPENAI_API_KEY=
GEMINI_API_KEY=

# Future vector database providers
QDRANT_URL=
QDRANT_API_KEY=
PINECONE_API_KEY=
PINECONE_INDEX=
