# App
NODE_ENV=development
PORT=3001
API_BASE_URL=http://localhost:3001
PUBLIC_API_BASE_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3000
PUBLIC_WEB_URL=http://localhost:3002
DEFAULT_SUPER_ADMIN_EMAIL=admin@example.com
DEFAULT_SUPER_ADMIN_NAME="Super Admin"
DEFAULT_SUPER_ADMIN_PASSWORD=Admin@12345

# Auth
JWT_SECRET=replace-with-a-long-random-development-secret
JWT_EXPIRES_IN=1d

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=ai_cms
MYSQL_USER=ai_cms_user
MYSQL_PASSWORD=ai_cms_password
MYSQL_ROOT_PASSWORD=password
DATABASE_URL="mysql://root:password@localhost:3306/ai_cms"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# Media library
MEDIA_UPLOAD_DIR=uploads/media
MAX_UPLOAD_SIZE_MB=5
CONTENT_IMPORT_UPLOAD_DIR=uploads/content-imports
MAX_CONTENT_IMPORT_FILE_SIZE_MB=25
CONTENT_IMPORT_FETCH_TIMEOUT_MS=10000
CONTENT_IMPORT_MAX_RESPONSE_BYTES=1048576
PUBLIC_MEDIA_BASE_URL=http://localhost:3000/uploads/media

# AI assistants
# Supported providers: openai, gemini
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
AI_MAX_TOKENS=1200
AI_TEMPERATURE=0.4

# Future vector database providers
QDRANT_URL=
QDRANT_API_KEY=
PINECONE_API_KEY=
PINECONE_INDEX=
