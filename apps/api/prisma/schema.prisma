generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum ContentStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  CHANGES_REQUESTED
  APPROVED
  PUBLISHED
  ARCHIVED
}

enum ContentType {
  PAGE
  BLOG
}

enum SenderType {
  VISITOR
  BOT
  ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum TemplateStatus {
  DRAFT
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum TemplateType {
  GOVERNMENT
  CORPORATE
  BLOG
  LANDING_PAGE
  CUSTOM
}

enum ComplianceStatus {
  PASS
  WARNING
  FAIL
  NOT_CHECKED
}

enum ComplianceSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AITemplateGenerationStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  SAVED_AS_TEMPLATE
}

enum DocumentStatus {
  DRAFT
  PROCESSING
  READY_FOR_REVIEW
  PUBLISHED
  ARCHIVED
  FAILED
}

enum DocumentType {
  PDF
  DOC
  DOCX
  XLS
  XLSX
  PPT
  PPTX
  IMAGE
  OTHER
}

enum DocumentMetadataJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  APPLIED
}

enum FormStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum FormFieldType {
  TEXT
  TEXTAREA
  EMAIL
  PHONE
  NUMBER
  DATE
  SELECT
  MULTI_SELECT
  RADIO
  CHECKBOX
  FILE_UPLOAD
  CONSENT
  HIDDEN
}

enum FormSubmissionStatus {
  NEW
  REVIEWED
  IN_PROGRESS
  CLOSED
  SPAM
}

enum FaqStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum FaqCategoryStatus {
  ACTIVE
  INACTIVE
}

enum TranslationJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  APPLIED
}

model User {
  id                 String            @id @default(cuid())
  email              String            @unique @db.VarChar(191)
  name               String            @db.VarChar(191)
  passwordHash       String?           @db.VarChar(255)
  status             UserStatus        @default(ACTIVE)
  roleId             String
  role               Role              @relation(fields: [roleId], references: [id])
  authoredPages      Page[]            @relation("PageAuthor")
  reviewedPages      Page[]            @relation("PageReviewer")
  publishedPages     Page[]            @relation("PagePublisher")
  authoredBlogPosts  BlogPost[]        @relation("BlogPostAuthor")
  reviewedBlogPosts  BlogPost[]        @relation("BlogPostReviewer")
  publishedBlogPosts BlogPost[]        @relation("BlogPostPublisher")
  uploadedMedia      Media[]           @relation("MediaUploadedBy")
  submittedWorkflows Workflow[]        @relation("WorkflowSubmittedBy")
  reviewWorkflows    Workflow[]        @relation("WorkflowReviewer")
  workflowHistory    WorkflowHistory[] @relation("WorkflowHistoryPerformedBy")
  notifications      Notification[]
  auditLogs          AuditLog[]
  aiUsageLogs        AIUsageLog[]
  assignedLeads      Lead[]            @relation("LeadAssignee")
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@index([roleId])
  @@index([status])
  @@map("users")
}

model Role {
  id           String     @id @default(cuid())
  name         String     @unique @db.VarChar(191)
  description  String?    @db.Text
  permissions  Json?      @db.Json
  isSystemRole Boolean    @default(false)
  status       UserStatus @default(ACTIVE)
  users        User[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([status])
  @@map("roles")
}

model Settings {
  id                    String   @id @default("default_settings")
  siteName              String   @default("AI CMS") @db.VarChar(191)
  siteDescription       String?  @db.Text
  siteLogo              String?  @db.VarChar(2048)
  defaultMetaTitle      String?  @db.VarChar(255)
  defaultMetaDescription String? @db.Text
  supportEmail          String?  @db.VarChar(191)
  chatbotEnabled        Boolean  @default(true)
  aiEnabled             Boolean  @default(true)
  maintenanceMode       Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@map("settings")
}

model Page {
  id              String        @id @default(cuid())
  title           String        @db.VarChar(255)
  slug            String        @unique @db.VarChar(191)
  excerpt         String?       @db.Text
  content         String?       @db.LongText
  featuredImage   String?       @db.VarChar(2048)
  status          ContentStatus @default(DRAFT)
  metaTitle       String?       @db.VarChar(255)
  metaDescription String?       @db.Text
  publishedAt     DateTime?
  authorId        String?
  reviewerId      String?
  publisherId     String?
  author          User?         @relation("PageAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  reviewer        User?         @relation("PageReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)
  publisher       User?         @relation("PagePublisher", fields: [publisherId], references: [id], onDelete: SetNull)
  categories      Category[]    @relation("PageCategories")
  tags            Tag[]         @relation("PageTags")
  media           Media[]       @relation("PageMedia")
  workflows       Workflow[]
  auditLogs       AuditLog[]
  aiUsageLogs     AIUsageLog[]
  deletedAt       DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([authorId])
  @@index([reviewerId])
  @@index([publisherId])
  @@index([status])
  @@index([deletedAt])
  @@map("pages")
}

model BlogPost {
  id              String        @id @default(cuid())
  title           String        @db.VarChar(255)
  slug            String        @unique @db.VarChar(191)
  excerpt         String?       @db.Text
  content         String?       @db.LongText
  featuredImage   String?       @db.VarChar(2048)
  status          ContentStatus @default(DRAFT)
  metaTitle       String?       @db.VarChar(255)
  metaDescription String?       @db.Text
  publishedAt     DateTime?
  categoryId      String?
  authorId        String?
  reviewerId      String?
  publisherId     String?
  category        Category?     @relation("BlogPostCategory", fields: [categoryId], references: [id], onDelete: SetNull)
  author          User?         @relation("BlogPostAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  reviewer        User?         @relation("BlogPostReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)
  publisher       User?         @relation("BlogPostPublisher", fields: [publisherId], references: [id], onDelete: SetNull)
  categories      Category[]    @relation("BlogPostCategories")
  tags            Tag[]         @relation("BlogPostTags")
  media           Media[]       @relation("BlogPostMedia")
  workflows       Workflow[]
  auditLogs       AuditLog[]
  aiUsageLogs     AIUsageLog[]
  deletedAt       DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([categoryId])
  @@index([authorId])
  @@index([reviewerId])
  @@index([publisherId])
  @@index([status])
  @@index([deletedAt])
  @@map("blog_posts")
}

model Category {
  id               String     @id @default(cuid())
  name             String     @db.VarChar(191)
  slug             String     @unique @db.VarChar(191)
  description      String?    @db.Text
  parentId         String?
  parent           Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children         Category[] @relation("CategoryHierarchy")
  pages            Page[]     @relation("PageCategories")
  blogPosts        BlogPost[] @relation("BlogPostCategories")
  primaryBlogPosts BlogPost[] @relation("BlogPostCategory")
  deletedAt        DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  @@index([parentId])
  @@index([deletedAt])
  @@map("categories")
}

model Tag {
  id        String     @id @default(cuid())
  name      String     @db.VarChar(191)
  slug      String     @unique @db.VarChar(191)
  pages     Page[]     @relation("PageTags")
  blogPosts BlogPost[] @relation("BlogPostTags")
  deletedAt DateTime?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([deletedAt])
  @@map("tags")
}

model Media {
  id           String     @id @default(cuid())
  originalName String     @db.VarChar(255)
  fileName     String     @db.VarChar(255)
  fileUrl      String     @db.VarChar(2048)
  mimeType     String     @db.VarChar(191)
  fileSize     Int
  altText      String?    @db.VarChar(255)
  caption      String?    @db.Text
  folder       String?    @db.VarChar(191)
  uploadedById String?
  uploadedBy   User?      @relation("MediaUploadedBy", fields: [uploadedById], references: [id], onDelete: SetNull)
  pages        Page[]     @relation("PageMedia")
  blogPosts    BlogPost[] @relation("BlogPostMedia")
  auditLogs    AuditLog[]
  deletedAt    DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([uploadedById])
  @@index([folder])
  @@index([mimeType])
  @@index([deletedAt])
  @@map("media")
}

model Workflow {
  id            String        @id @default(cuid())
  status        ContentStatus @default(SUBMITTED)
  note          String?       @db.Text
  pageId        String?
  blogPostId    String?
  submittedById String?
  reviewerId    String?
  page          Page?         @relation(fields: [pageId], references: [id], onDelete: Cascade)
  blogPost      BlogPost?     @relation(fields: [blogPostId], references: [id], onDelete: Cascade)
  submittedBy   User?         @relation("WorkflowSubmittedBy", fields: [submittedById], references: [id], onDelete: SetNull)
  reviewer      User?         @relation("WorkflowReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([pageId])
  @@index([blogPostId])
  @@index([submittedById])
  @@index([reviewerId])
  @@index([status])
  @@map("workflows")
}

model WorkflowHistory {
  id            String         @id @default(cuid())
  contentType   ContentType
  contentId     String         @db.VarChar(191)
  fromStatus    ContentStatus?
  toStatus      ContentStatus
  action        String         @db.VarChar(191)
  comment       String?        @db.Text
  performedById String?
  performedBy   User?          @relation("WorkflowHistoryPerformedBy", fields: [performedById], references: [id], onDelete: SetNull)
  createdAt     DateTime       @default(now())

  @@index([contentType, contentId])
  @@index([performedById])
  @@index([toStatus])
  @@map("workflow_history")
}

model Notification {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title      String   @db.VarChar(255)
  message    String   @db.Text
  type       String   @db.VarChar(50)
  isRead     Boolean  @default(false)
  entityType String?  @db.VarChar(50)
  entityId   String?  @db.VarChar(191)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId, isRead])
  @@index([entityType, entityId])
  @@map("notifications")
}

model AuditLog {
  id         String    @id @default(cuid())
  action     String    @db.VarChar(191)
  entityType String    @db.VarChar(191)
  entityId   String    @db.VarChar(191)
  metadata   Json?
  userId     String?
  pageId     String?
  blogPostId String?
  mediaId    String?
  user       User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  page       Page?     @relation(fields: [pageId], references: [id], onDelete: SetNull)
  blogPost   BlogPost? @relation(fields: [blogPostId], references: [id], onDelete: SetNull)
  media      Media?    @relation(fields: [mediaId], references: [id], onDelete: SetNull)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([userId])
  @@index([pageId])
  @@index([blogPostId])
  @@index([mediaId])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

model AIUsageLog {
  id               String    @id @default(cuid())
  provider         String    @db.VarChar(191)
  action           String    @default("unknown") @db.VarChar(191)
  model            String?   @db.VarChar(191)
  promptSummary    String?   @db.Text
  tokenInput       Int       @default(0)
  tokenOutput      Int       @default(0)
  modelName        String?   @db.VarChar(191)
  feature          String    @db.VarChar(191)
  promptTokens     Int       @default(0)
  completionTokens Int       @default(0)
  totalTokens      Int       @default(0)
  costUsd          Decimal?  @db.Decimal(10, 4)
  metadata         Json?
  userId           String?
  pageId           String?
  blogPostId       String?
  user             User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  page             Page?     @relation(fields: [pageId], references: [id], onDelete: SetNull)
  blogPost         BlogPost? @relation(fields: [blogPostId], references: [id], onDelete: SetNull)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([userId])
  @@index([pageId])
  @@index([blogPostId])
  @@index([provider])
  @@index([action])
  @@index([feature])
  @@map("ai_usage_logs")
}

model ChatbotConversation {
  id         String           @id @default(cuid())
  sessionId  String           @unique @db.VarChar(191)
  visitorId  String?          @db.VarChar(191)
  sourcePage String?          @db.VarChar(2048)
  startedAt  DateTime         @default(now())
  leadId     String?          @unique
  lead       Lead?            @relation(fields: [leadId], references: [id], onDelete: SetNull)
  messages   ChatbotMessage[]
  endedAt    DateTime?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@index([visitorId])
  @@map("chatbot_conversations")
}

model ChatbotMessage {
  id             String              @id @default(cuid())
  conversationId String
  senderType     SenderType
  content        String              @db.LongText
  metadata       Json?
  conversation   ChatbotConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([conversationId])
  @@index([senderType])
  @@map("chatbot_messages")
}

model Lead {
  id           String               @id @default(cuid())
  name         String?              @db.VarChar(191)
  email        String?              @db.VarChar(191)
  phone        String?              @db.VarChar(50)
  company      String?              @db.VarChar(191)
  message      String?              @db.Text
  source       String?              @db.VarChar(191)
  sourcePage   String?              @db.VarChar(2048)
  status       String               @default("NEW") @db.VarChar(50)
  assignedToId String?
  assignedTo   User?                @relation("LeadAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  conversation ChatbotConversation?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  @@index([assignedToId])
  @@index([email])
  @@index([status])
  @@map("leads")
}

model ChatbotSettings {
  id                 String   @id @default(cuid())
  isEnabled          Boolean  @default(true)
  greetingMessage    String   @default("Hi! How can I help you today?") @db.VarChar(500)
  fallbackMessage    String   @default("I do not have that information yet. Please contact support and we will help you.") @db.VarChar(500)
  leadCaptureEnabled Boolean  @default(true)
  supportEmail       String?  @db.VarChar(191)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("chatbot_settings")
}

model WebsiteTemplate {
  id              String           @id @default(cuid())
  name            String           @db.VarChar(255)
  slug            String           @unique @db.VarChar(191)
  description     String?          @db.Text
  version         String           @db.VarChar(50)
  templateType    TemplateType     @default(CUSTOM)
  status          TemplateStatus   @default(DRAFT)
  isActive        Boolean          @default(false)
  thumbnailUrl    String?          @db.VarChar(2048)
  configJson      Json?            @db.Json
  complianceJson  Json?            @db.Json
  fileKey         String?          @db.VarChar(500)
  fileUrl         String?          @db.VarChar(2048)
  storageProvider String           @default("local") @db.VarChar(50)
  uploadedById    String?
  deletedAt       DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  versions        TemplateVersion[]
  complianceChecks TemplateComplianceCheck[]
  regions         TemplateRegion[]
  regionModules   TemplateRegionModule[]

  @@index([status])
  @@index([isActive])
  @@index([templateType])
  @@index([deletedAt])
  @@map("website_templates")
}

model TemplateVersion {
  id             String          @id @default(cuid())
  templateId     String
  template       WebsiteTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  version        String          @db.VarChar(50)
  fileKey        String?         @db.VarChar(500)
  fileUrl        String?         @db.VarChar(2048)
  configJson     Json?           @db.Json
  complianceJson Json?           @db.Json
  uploadedById   String?
  createdAt      DateTime        @default(now())

  @@index([templateId])
  @@map("template_versions")
}

model TemplateComplianceCheck {
  id             String             @id @default(cuid())
  templateId     String
  template       WebsiteTemplate    @relation(fields: [templateId], references: [id], onDelete: Cascade)
  checkKey       String             @db.VarChar(191)
  checkTitle     String             @db.VarChar(255)
  checkCategory  String             @db.VarChar(100)
  status         ComplianceStatus   @default(NOT_CHECKED)
  severity       ComplianceSeverity @default(MEDIUM)
  message        String?            @db.Text
  recommendation String?            @db.Text
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@index([templateId])
  @@index([checkCategory])
  @@index([status])
  @@map("template_compliance_checks")
}

model AITemplateGenerationJob {
  id                String                      @id @default(cuid())
  screenshotUrl     String?                     @db.VarChar(2048)
  status            AITemplateGenerationStatus  @default(PENDING)
  prompt            String?                     @db.Text
  templateType      TemplateType                @default(GOVERNMENT)
  aiProvider        String?                     @db.VarChar(100)
  aiModel           String?                     @db.VarChar(100)
  generatedConfigJson Json?                     @db.Json
  generatedHtml     String?                     @db.LongText
  generatedCss      String?                     @db.LongText
  errorMessage      String?                     @db.Text
  createdById       String?
  createdAt         DateTime                    @default(now())
  updatedAt         DateTime                    @updatedAt

  @@index([status])
  @@index([createdById])
  @@map("ai_template_generation_jobs")
}

model TemplateRegion {
  id          String                 @id @default(cuid())
  templateId  String
  template    WebsiteTemplate        @relation(fields: [templateId], references: [id], onDelete: Cascade)
  regionKey   String                 @db.VarChar(100)
  regionName  String                 @db.VarChar(255)
  description String?                @db.Text
  regionType  String                 @default("CONTENT") @db.VarChar(50)
  sortOrder   Int                    @default(0)
  isRequired  Boolean                @default(false)
  isActive    Boolean                @default(true)
  modules     TemplateRegionModule[]
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  @@unique([templateId, regionKey])
  @@index([templateId])
  @@map("template_regions")
}

model TemplateRegionModule {
  id           String          @id @default(cuid())
  templateId   String
  template     WebsiteTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  regionId     String
  region       TemplateRegion  @relation(fields: [regionId], references: [id], onDelete: Cascade)
  moduleType   String          @db.VarChar(100)
  moduleKey    String          @db.VarChar(191)
  displayTitle String          @db.VarChar(255)
  configJson   Json?           @db.Json
  sortOrder    Int             @default(0)
  isVisible    Boolean         @default(true)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([templateId])
  @@index([regionId])
  @@map("template_region_modules")
}

model TemplateModuleRegistry {
  id                       String   @id @default(cuid())
  moduleKey                String   @unique @db.VarChar(191)
  moduleName               String   @db.VarChar(255)
  moduleType               String   @db.VarChar(100)
  description              String?  @db.Text
  category                 String   @default("Content") @db.VarChar(100)
  isPublicEnabled          Boolean  @default(true)
  isSystemModule           Boolean  @default(false)
  isActive                 Boolean  @default(true)
  defaultConfigJson        Json?    @db.Json
  supportedRegionTypesJson Json?    @db.Json
  requiredPermissionsJson  Json?    @db.Json
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@index([category])
  @@index([isActive])
  @@index([isPublicEnabled])
  @@map("template_module_registry")
}

model AiProviderConfig {
  id                  String         @id @default(cuid())
  providerKey         String         @unique @db.VarChar(50)
  providerName        String         @db.VarChar(191)
  isEnabled           Boolean        @default(false)
  isDefault           Boolean        @default(false)
  apiKeyEncrypted     String?        @db.Text
  baseUrl             String?        @db.VarChar(2048)
  organizationId      String?        @db.VarChar(191)
  projectId           String?        @db.VarChar(191)
  defaultTextModel    String?        @db.VarChar(191)
  defaultVisionModel  String?        @db.VarChar(191)
  defaultEmbeddingModel String?      @db.VarChar(191)
  capabilitiesJson    Json?          @db.Json
  settingsJson        Json?          @db.Json
  pricingNotes        String?        @db.Text
  models              AiModelConfig[]
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  @@map("ai_provider_configs")
}

model AiModelConfig {
  id                  String          @id @default(cuid())
  providerConfigId    String
  providerConfig      AiProviderConfig @relation(fields: [providerConfigId], references: [id], onDelete: Cascade)
  modelKey            String          @db.VarChar(191)
  modelName           String          @db.VarChar(255)
  modelType           String          @default("TEXT") @db.VarChar(50)
  pricingType         String          @default("UNKNOWN") @db.VarChar(50)
  isFree              Boolean         @default(false)
  isFreeTier          Boolean         @default(false)
  isPaid              Boolean         @default(false)
  isEnabled           Boolean         @default(true)
  isDefault           Boolean         @default(false)
  maxTokens           Int?
  contextWindow       Int?
  supportsVision      Boolean         @default(false)
  supportsEmbeddings  Boolean         @default(false)
  supportsJson        Boolean         @default(true)
  supportsStreaming   Boolean         @default(false)
  costInputPerMillion Float?
  costOutputPerMillion Float?
  freeTierLimitJson   Json?           @db.Json
  pricingNotes        String?         @db.Text
  settingsJson        Json?           @db.Json
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  @@unique([providerConfigId, modelKey])
  @@index([providerConfigId])
  @@index([pricingType])
  @@index([isEnabled])
  @@map("ai_model_configs")
}

model AiRoutingRule {
  id                   String   @id @default(cuid())
  taskType             String   @db.VarChar(100)
  selectionMode        String   @default("AUTO") @db.VarChar(20)
  costPreference       String   @default("PREFER_FREE") @db.VarChar(50)
  preferredProviderKey String?  @db.VarChar(50)
  preferredModelKey    String?  @db.VarChar(191)
  fallbackProviderKey  String?  @db.VarChar(50)
  fallbackModelKey     String?  @db.VarChar(191)
  allowPaidModels      Boolean  @default(false)
  requireFreeModel     Boolean  @default(true)
  priorityJson         Json?    @db.Json
  isEnabled            Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@unique([taskType])
  @@map("ai_routing_rules")
}

model CmsModule {
  id                  String   @id @default(cuid())
  moduleKey           String   @unique @db.VarChar(100)
  moduleName          String   @db.VarChar(255)
  description         String?  @db.Text
  category            String   @default("CONTENT") @db.VarChar(50)
  version             String   @default("1.0.0") @db.VarChar(20)
  icon                String?  @db.VarChar(100)
  routePath           String?  @db.VarChar(255)
  publicRoutePath     String?  @db.VarChar(255)
  isSystemModule      Boolean  @default(false)
  isCoreModule        Boolean  @default(false)
  isEnabledGlobally   Boolean  @default(true)
  isPublicEnabled     Boolean  @default(false)
  isAdminVisible      Boolean  @default(true)
